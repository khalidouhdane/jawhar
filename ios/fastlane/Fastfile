default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight using App Store Connect API Key"
  lane :beta do
    # 1. Authenticate with App Store Connect API
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # 2. Create a temporary keychain on the runner
    create_keychain(
      name: "temporary_keychain",
      password: "temporary_password",
      default_keychain: true,
      unlock: true,
      timeout: 3600
    )

    # 3. Download/Generate the signing certificates
    keychain_path = lane_context[SharedValues::KEYCHAIN_PATH]
    if keychain_path
      keychain_path = File.expand_path(keychain_path)
      if !File.exist?(keychain_path)
        if File.exist?("#{keychain_path}-db")
          keychain_path = "#{keychain_path}-db"
        elsif File.exist?("#{keychain_path}.keychain-db")
          keychain_path = "#{keychain_path}.keychain-db"
        end
      end
    end

    # 2.5 Revoke oldest active Distribution certificate ONLY if we are near the limit
    begin
      UI.message("Checking existing distribution certificates on the Developer Portal to prevent hitting Apple's limit...")
      token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key: Base64.decode64(ENV["ASC_KEY_CONTENT"])
      )
      Spaceship::ConnectAPI.token = token
      certs = Spaceship::ConnectAPI::Certificate.all
      UI.message("Found #{certs.count} total certificates on the portal.")
      
      # Filter for Apple Distribution / iOS Distribution certificates
      dist_certs = certs.select do |c|
        type = c.certificate_type
        type && (type.include?("DISTRIBUTION") || type.include?("Distribution"))
      end
      
      UI.message("Found #{dist_certs.count} active distribution certificates on the portal.")
      
      # Every CI run creates a fresh certificate (the runner keychain is
      # ephemeral, so existing certs are never reusable here and exist only
      # as dead weight against Apple's 3-cert limit). Revoke ALL active
      # distribution certificates, then wait out the portal's propagation
      # lag — revoke-one-then-create-immediately still hit "maximum number
      # of certificates" 3 seconds later (run 27400502914).
      if dist_certs.count >= 1
        dist_certs.each do |cert|
          UI.message("Revoking distribution certificate: #{cert.name} (ID: #{cert.id}, Expires: #{cert.expiration_date})")
          cert.delete!
        end
        UI.message("Revoked #{dist_certs.count} distribution certificate(s); waiting 15s for portal propagation...")
        sleep(15)
      else
        UI.message("No active distribution certificates to clear.")
      end
    rescue => e
      UI.error("Error while managing developer portal certificates: #{e.message}")
    end

    get_certificates(
      api_key: api_key,
      development: false,
      force: false,
      keychain_path: keychain_path,
      keychain_password: "temporary_password"
    )

    # 4. Download/Generate the provisioning profiles
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.alphafoundr.jawhar",
      filename: "profile.mobileprovision"
    )

    # 5. Extract Team ID and profile name from the downloaded provisioning profile
    profile_name = lane_context[SharedValues::SIGH_NAME]
    profile_path = lane_context[SharedValues::SIGH_PROFILE_PATH]
    # Decode the provisioning profile plist to extract TeamIdentifier
    sh("security cms -D -i '#{profile_path}' > /tmp/profile_decoded.plist")
    require 'plist'
    profile_plist = Plist.parse_xml("/tmp/profile_decoded.plist")
    team_id = profile_plist["TeamIdentifier"].first
    UI.message("Successfully read provisioning profile: #{profile_name} (Team ID: #{team_id})")

    # 6. Disable automatic signing and update project settings to use our profile
    update_code_signing_settings(
      path: "Runner.xcodeproj",
      use_automatic_signing: false,
      team_id: team_id,
      bundle_identifier: "com.alphafoundr.jawhar",
      profile_name: profile_name,
      code_sign_identity: "iPhone Distribution"
    )

    # 7. Dynamically generate ExportOptions.plist with manual signing and correct Team ID
    profile_uuid = lane_context[SharedValues::SIGH_UUID]
    # Write to ios/ directory (parent of fastlane/) since flutter expects ios/ExportOptions.plist from project root
    export_plist_path = File.join(Dir.pwd, "..", "ExportOptions.plist")
    export_options_content = <<~XML
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
      \t<key>method</key>
      \t<string>app-store</string>
      \t<key>signingStyle</key>
      \t<string>manual</string>
      \t<key>teamID</key>
      \t<string>#{team_id}</string>
      \t<key>signingCertificate</key>
      \t<string>Apple Distribution</string>
      \t<key>provisioningProfiles</key>
      \t<dict>
      \t\t<key>com.alphafoundr.jawhar</key>
      \t\t<string>#{profile_name}</string>
      \t</dict>
      \t<key>stripSwiftSymbols</key>
      \t<true/>
      \t<key>uploadSymbols</key>
      \t<true/>
      </dict>
      </plist>
    XML
    File.write(export_plist_path, export_options_content)
    UI.message("Successfully generated ExportOptions.plist at #{export_plist_path} with manual signing!")
    UI.message("Profile name: #{profile_name}, UUID: #{profile_uuid}, Team ID: #{team_id}")

    # 8. Build the signed IPA using Flutter
    sh("cd ../.. && flutter build ipa --release --export-options-plist=ios/ExportOptions.plist --dart-define-from-file=.env")

    # 9. Upload to App Store Connect / TestFlight
    project_root = File.expand_path("../..", Dir.pwd)
    ipa_path = Dir[File.join(project_root, "build/ios/ipa/*.ipa")].first
    UI.message("Found IPA at: #{ipa_path}")
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end
end

