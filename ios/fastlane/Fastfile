default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight using App Store Connect API Key"
  lane :beta do
    # 1. Authenticate with App Store Connect API
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # 2. Create a temporary keychain on the runner
    create_keychain(
      name: "temporary_keychain",
      password: "temporary_password",
      default_keychain: true,
      unlock: true,
      timeout: 3600
    )

    # 3. Download/Generate the signing certificates
    keychain_path = lane_context[SharedValues::KEYCHAIN_PATH]
    if keychain_path
      keychain_path = File.expand_path(keychain_path)
      if !File.exist?(keychain_path)
        if File.exist?("#{keychain_path}-db")
          keychain_path = "#{keychain_path}-db"
        elsif File.exist?("#{keychain_path}.keychain-db")
          keychain_path = "#{keychain_path}.keychain-db"
        end
      end
    end

    # 2.5 Revoke existing active Distribution certificates to prevent hitting the limit
    begin
      UI.message("Checking existing distribution certificates on the Developer Portal to prevent hitting the 2-cert limit...")
      token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key: Base64.decode64(ENV["ASC_KEY_CONTENT"])
      )
      Spaceship::ConnectAPI.token = token
      certs = Spaceship::ConnectAPI::Certificate.all
      UI.message("Found #{certs.count} total certificates on the portal.")
      
      certs.each do |c|
        type = c.certificate_type
        if type && (type.include?("DISTRIBUTION") || type.include?("Distribution"))
          UI.message("Revoking certificate: #{c.name} (ID: #{c.id}, Type: #{type}, Expires: #{c.expiration_date})")
          c.delete!
        end
      end
      UI.message("Successfully cleared active Distribution certificates.")
    rescue => e
      UI.error("Error while cleaning up developer portal certificates: #{e.message}")
    end

    get_certificates(
      api_key: api_key,
      development: false,
      force: false,
      keychain_path: keychain_path,
      keychain_password: "temporary_password"
    )

    # 4. Download/Generate the provisioning profiles
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.memorize.quran.ai",
      filename: "profile.mobileprovision"
    )

    # 5. Extract Team ID and profile name from the downloaded provisioning profile
    profile_name = lane_context[SharedValues::SIGH_NAME]
    # Decode the provisioning profile plist to extract TeamIdentifier
    sh("security cms -D -i profile.mobileprovision > /tmp/profile_decoded.plist")
    require 'plist'
    profile_plist = Plist.parse_xml("/tmp/profile_decoded.plist")
    team_id = profile_plist["TeamIdentifier"].first
    UI.message("Successfully read provisioning profile: #{profile_name} (Team ID: #{team_id})")

    # 6. Disable automatic signing and update project settings to use our profile
    update_code_signing_settings(
      path: "Runner.xcodeproj",
      use_automatic_signing: false,
      team_id: team_id,
      bundle_identifier: "com.memorize.quran.ai",
      profile_name: profile_name,
      code_sign_identity: "iPhone Distribution"
    )

    # 7. Dynamically generate ExportOptions.plist with manual signing and correct Team ID
    export_options_content = <<~XML
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
      \t<key>method</key>
      \t<string>app-store</string>
      \t<key>signingStyle</key>
      \t<string>manual</string>
      \t<key>teamID</key>
      \t<string>#{team_id}</string>
      \t<key>provisioningProfiles</key>
      \t<dict>
      \t\t<key>com.memorize.quran.ai</key>
      \t\t<string>#{profile_name}</string>
      \t</dict>
      \t<key>stripSwiftSymbols</key>
      \t<true/>
      \t<key>uploadSymbols</key>
      \t<true/>
      </dict>
      </plist>
    XML
    File.write("ExportOptions.plist", export_options_content)
    UI.message("Successfully generated ExportOptions.plist with manual signing!")

    # 8. Build the signed IPA using Flutter
    sh("cd ../.. && flutter build ipa --release --export-options-plist=ios/ExportOptions.plist --dart-define-from-file=.env")

    # 9. Upload to App Store Connect / TestFlight
    upload_to_testflight(
      api_key: api_key,
      ipa: "../../build/ios/ipa/*.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end

