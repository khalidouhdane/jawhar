{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "test:unit": "npm run build && node --test test/security.test.js",
    "test:rules": "firebase emulators:exec --config ../firebase.json --project demo-quran-app --only firestore \"node --test test/firestore.rules.test.js\"",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google/genai": "^2.8.0",
    "firebase-admin": "12.7.0",
    "firebase-functions": "5.1.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "eslint": "8.57.1",
    "eslint-config-google": "0.14.0",
    "eslint-plugin-import": "2.32.0",
    "firebase": "12.14.0",
    "firebase-functions-test": "3.5.0",
    "firebase-tools": "15.18.0",
    "typescript": "^5.9.3"
  },
  "private": true
}
